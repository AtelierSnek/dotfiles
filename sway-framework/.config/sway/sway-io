# Specific IO File for our Framework 12

# ==== Inputs ====

input "PIXA3854:00 093A:0239 Touchpad" {
  accel_profile flat
  pointer_accel 0
  click_method clickfinger
  clickfinger_button_map lrm
  tap_button_map lrm
  natural_scroll enabled
  scroll_method two_finger
  scroll_factor 1.5
  dwt enabled #Disable While Typing
}

input "ILIT2901:0 222A:5539" {
  map_to_output "eDP-1"
}

# ==== Outputs ====

output eDP-1 {
  resolution 1920x1200
  scale 1.0
  adaptive_sync on
  allow_tearing yes
  max_render_time off
  pos 0 0
}

output HDMI-A-1 {
  resolution 1920x1080
  adaptive_sync on
  pos 1920 0
  scale 1.0
}

bindsym $mod+p output HDMI-A-1 power toggle

